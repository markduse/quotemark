# ─── Supabase ───────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Stripe (Netlify Functions only, never expose to frontend) ───
# Get these from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...           # Your $5/mo recurring price ID
STRIPE_WEBHOOK_SECRET=whsec_...     # From Stripe → Webhooks → your endpoint

# ─── Supabase Service Role (Netlify Functions only) ──────────
# Settings → API → service_role key  (NEVER expose to frontend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Site URL ────────────────────────────────────────────────
SITE_URL=https://quotemarko.netlify.app
